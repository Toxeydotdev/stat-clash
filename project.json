{
  "$schema": "node_modules/nx/schemas/project-schema.json",
  "name": "workspace",
  "projectType": "application",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default", { "externalDependencies": ["oxlint"] }],
      "options": {
        "command": "oxlint . --deny-warnings"
      }
    },
    "format-check": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default", { "externalDependencies": ["oxfmt"] }],
      "options": {
        "command": "oxfmt --check ."
      }
    },
    "spec-check": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{workspaceRoot}/openspec/**/*",
        { "externalDependencies": ["@fission-ai/openspec"] }
      ],
      "options": {
        "command": "openspec validate --all --strict"
      }
    }
  }
}
